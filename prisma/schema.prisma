generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}
model users {
  instance_id                 String?                @db.Uuid
  id                          String                 @id @db.Uuid
  aud                         String?                @db.VarChar(255)
  role                        String?                @db.VarChar(255)
  email                       String?                @db.VarChar(255)
  encrypted_password          String?                @db.VarChar(255)
  email_confirmed_at          DateTime?              @db.Timestamptz(6)
  invited_at                  DateTime?              @db.Timestamptz(6)
  confirmation_token          String?                @db.VarChar(255)
  confirmation_sent_at        DateTime?              @db.Timestamptz(6)
  recovery_token              String?                @db.VarChar(255)
  recovery_sent_at            DateTime?              @db.Timestamptz(6)
  email_change_token_new      String?                @db.VarChar(255)
  email_change                String?                @db.VarChar(255)
  email_change_sent_at        DateTime?              @db.Timestamptz(6)
  last_sign_in_at             DateTime?              @db.Timestamptz(6)
  raw_app_meta_data           Json?
  raw_user_meta_data          Json?
  is_super_admin              Boolean?
  created_at                  DateTime?              @db.Timestamptz(6)
  updated_at                  DateTime?              @db.Timestamptz(6)
  phone                       String?                @unique
  phone_confirmed_at          DateTime?              @db.Timestamptz(6)
  phone_change                String?                @default("")
  phone_change_token          String?                @default("") @db.VarChar(255)
  phone_change_sent_at        DateTime?              @db.Timestamptz(6)
  confirmed_at                DateTime?              @default(dbgenerated("LEAST(email_confirmed_at, phone_confirmed_at)")) @db.Timestamptz(6)
  email_change_token_current  String?                @default("") @db.VarChar(255)
  email_change_confirm_status Int?                   @default(0) @db.SmallInt
  banned_until                DateTime?              @db.Timestamptz(6)
  reauthentication_token      String?                @default("") @db.VarChar(255)
  reauthentication_sent_at    DateTime?              @db.Timestamptz(6)
  is_sso_user                 Boolean                @default(false)
  deleted_at                  DateTime?              @db.Timestamptz(6)
  is_anonymous                Boolean                @default(false)
  identities                  identities[]
  mfa_factors                 mfa_factors[]
  oauth_authorizations        oauth_authorizations[]
  oauth_consents              oauth_consents[]
  one_time_tokens             one_time_tokens[]
  sessions                    sessions[]
  profiles                    profiles?

  @@index([instance_id])
  @@index([is_anonymous])
  @@schema("auth")
}

model comments {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String     @db.Uuid
  recipe_id      String     @db.Uuid
  parent_id      String?    @db.Uuid
  content        String
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?  @db.Timestamptz(6)
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_comments comments[] @relation("commentsTocomments")
  recipes        recipes    @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles       profiles   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model conversations {
  id                                        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user1_id                                  String?    @db.Uuid
  user2_id                                  String?    @db.Uuid
  last_message_at                           DateTime?  @default(now()) @db.Timestamptz(6)
  profiles_conversations_user1_idToprofiles profiles?  @relation("conversations_user1_idToprofiles", fields: [user1_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_conversations_user2_idToprofiles profiles?  @relation("conversations_user2_idToprofiles", fields: [user2_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                                  messages[]

  @@unique([user1_id, user2_id])
  @@schema("public")
}

model follows {
  follower_id                             String   @db.Uuid
  following_id                            String   @db.Uuid
  profiles_follows_follower_idToprofiles  profiles @relation("follows_follower_idToprofiles", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_follows_following_idToprofiles profiles @relation("follows_following_idToprofiles", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([follower_id, following_id])
  @@schema("public")
}

model likes {
  user_id    String    @db.Uuid
  recipe_id  String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  recipes    recipes   @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles   profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, recipe_id])
  @@schema("public")
}

model messages {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String?        @db.Uuid
  sender_id       String?        @db.Uuid
  content         String
  is_read         Boolean?       @default(false)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  conversations   conversations? @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles        profiles?      @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model notifications {
  id                                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiver_id                                  String    @db.Uuid
  sender_id                                    String    @db.Uuid
  title                                        String
  description                                  String
  type                                         String
  recipe_id                                    String?   @db.Uuid
  is_read                                      Boolean?  @default(false)
  created_at                                   DateTime? @default(now()) @db.Timestamptz(6)
  profiles_notifications_receiver_idToprofiles profiles  @relation("notifications_receiver_idToprofiles", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  recipes                                      recipes?  @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_notifications_sender_idToprofiles   profiles  @relation("notifications_sender_idToprofiles", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model profiles {
  id                                                String           @id @db.Uuid
  username                                          String?          @unique
  first_name                                        String?
  last_name                                         String?
  full_name                                         String?
  email                                             String           @unique
  avatar_url                                        String?
  bio                                               String?
  social_media                                      Json?            @default("{}")
  created_at                                        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                                        DateTime?        @db.Timestamptz(6)
  comments                                          comments[]
  conversations_conversations_user1_idToprofiles    conversations[]  @relation("conversations_user1_idToprofiles")
  conversations_conversations_user2_idToprofiles    conversations[]  @relation("conversations_user2_idToprofiles")
  follows_follows_follower_idToprofiles             follows[]        @relation("follows_follower_idToprofiles")
  follows_follows_following_idToprofiles            follows[]        @relation("follows_following_idToprofiles")
  likes                                             likes[]
  messages                                          messages[]
  notifications_notifications_receiver_idToprofiles notifications[]  @relation("notifications_receiver_idToprofiles")
  notifications_notifications_sender_idToprofiles   notifications[]  @relation("notifications_sender_idToprofiles")
  users                                             users            @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  recipes                                           recipes[]
  saved_recipes                                     saved_recipes[]
  shared_recipes                                    shared_recipes[]

  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model recipes {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String               @db.Uuid
  title              String
  description        String?
  image_url          String?
  prep_time_mins     Int?
  difficulty         String?
  calories           Int?
  is_published       Boolean?             @default(false)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @db.Timestamptz(6)
  comments           comments[]
  likes              likes[]
  notifications      notifications[]
  recipe_ingredients recipe_ingredients[]
  recipe_steps       recipe_steps[]
  profiles           profiles             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  saved_recipes      saved_recipes[]
  shared_recipes     shared_recipes[]

  @@schema("public")
}

model shared_recipes {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String?   @db.Uuid
  recipe_id String?   @db.Uuid
  comment   String?
  shared_at DateTime? @default(now()) @db.Timestamptz(6)
  recipes   recipes?  @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles  profiles? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model recipe_ingredients {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipe_id   String  @db.Uuid
  name        String
  amount      String
  unit        String?
  order_index Int
  recipes     recipes @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model recipe_steps {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipe_id   String  @db.Uuid
  step_number Int
  instruction String
  recipes     recipes @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model saved_recipes {
  user_id   String    @db.Uuid
  recipe_id String    @db.Uuid
  saved_at  DateTime? @default(now()) @db.Timestamptz(6)
  recipes   recipes   @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles  profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, recipe_id])
  @@schema("public")
}