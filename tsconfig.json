{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "baseUrl": ".", 
    "paths": {
      "@utils/*": ["./src/utils/*"],
      "@config/*": ["./src/config/*"],
      "@enums/*": ["./src/enums/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@types/*": ["./src/types/*"],
      "@module/*":["./src/module/*"],
      "@docs/*":["./src/docs/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "files": true,
    "transpileOnly": true
  }
}