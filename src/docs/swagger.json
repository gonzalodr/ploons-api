    "/feed": {
      "get": {
        "tags": [
          "Feed"
        ],
        "summary": "Obtener feed de seguidos (Privado)",
        "description": "Retorna las publicaciones de los usuarios a los que el usuario autenticado sigue.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Número de página"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Cantidad de resultados por página"
          }
        ],
        "responses": {
          "200": {
            "description": "Feed obtenido correctamente"
          }
        }
      }
    },
    "/feed/trending": {
      "get": {
        "tags": [
          "Feed"
        ],
        "summary": "Obtener tendencias (Público/Opcional)",
        "description": "Retorna las publicaciones más populares. Si se envía token, permite saber si el usuario dio like a las publicaciones.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tendencias obtenidas correctamente"
          }
        }
      }
    },
    "/follow/toggle/{followingId}": {
      "post": {
        "tags": [
          "Follows"
        ],
        "summary": "Seguir o dejar de seguir a un usuario",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "followingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del usuario al que se desea seguir/unfollow"
          }
        ],
        "responses": {
          "200": {
            "description": "Acción realizada con éxito"
          }
        }
      }
    },
    "/follow/me/followers": {
      "get": {
        "tags": [
          "Follows"
        ],
        "summary": "Listar mis seguidores",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
