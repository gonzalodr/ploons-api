                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "content": {
                          "type": "string"
                        },
                        "created_at": {
                          "type": "string"
                        },
                        "replies_count": {
                          "type": "string"
                        },
                        "author": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string"
                            },
                            "username": {
                              "type": "string"
                            },
                            "first_name": {
                              "type": "string"
                            },
                            "last_name": {
                              "type": "string"
                            },
                            "avatar_url": {
                              "type": "string"
                            },
                            "relationship": {
                              "type": "object",
                              "properties": {
                                "i_am_following": {
                                  "type": "boolean"
                                },
                                "is_following_me": {
                                  "type": "boolean"
                                },
                                "is_mutual": {
                                  "type": "boolean"
                                },
                                "is_me": {
                                  "type": "boolean"
                                }
                              }
                            }
                          }
                        },
                        "replying_to": {
                          "type": "object",
                          "properties": {
                            "id": {
