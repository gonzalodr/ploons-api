                            "first_name": {
                              "type": "string"
                            },
                            "last_name": {
                              "type": "string"
                            },
                            "avatar_url": {
                              "type": "string"
                            },
                            "relationship": {
                              "type": "object",
                              "properties": {
                                "i_am_following": {
                                  "type": "boolean"
                                },
                                "is_following_me": {
                                  "type": "boolean"
                                },
                                "is_mutual": {
                                  "type": "boolean"
                                },
                                "is_me": {
