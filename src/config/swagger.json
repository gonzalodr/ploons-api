{
  "openapi": "3.0.0",
  "info": {
    "title": "Ploons API",
    "version": "1.0.0",
    "description": "API modular para la red social de Foodies Ploons"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "refreshToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Refresh-Token"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Iniciar sesión",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registro de nuevo usuario",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario creado, OTP enviado"
          }
        }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Verificar OTP de registro",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cuenta verificada"
          }
        }
      }
    },
    "/auth/refresh-token": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Refrescar el Access Token",
        "security": [
          {
            "refreshToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Token renovado"
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Solicitar recuperación de contraseña",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP de recuperación enviado"
          }
        }
      }
    },
    "/auth/verify-reset-otp": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Verificar OTP para cambio de contraseña",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP válido"
          }
        }
      }
    },
    "/auth/reset-password": {
      "patch": {
        "tags": [
          "Auth"
        ],
        "summary": "Cambiar contraseña (Reset)",
        "security": [
          {
            "bearerAuth": [],
            "refreshToken": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": {
                    "type": "string"
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contraseña actualizada"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Cerrar sesión",
        "security": [
          {
            "bearerAuth": [],
            "refreshToken": []
          }
        ],
        "responses": {
          "204": {
            "description": "Sesión cerrada"
          }
        }
      }
    },

    
    "/comment/recipe/{recipeId}": {
      "post": {
        "tags": [
          "Comments"
        ],
        "summary": "Crear comentario en una receta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID de la receta a comentar"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comentario creado"
          }
        }
      },
      "get": {
        "tags": [
          "Comments"
        ],
        "summary": "Obtener comentarios principales de una receta",
        "description": "Lista los comentarios que no son respuestas (parents)",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de comentarios obtenida"
          }
        }
      }
    },
    "/comment/recipe/reply/{parentId}": {
      "post": {
        "tags": [
          "Comments"
        ],
        "summary": "Responder a un comentario (Reply)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "parentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del comentario al que se responde"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Respuesta creada"
          }
        }
      }
    },
    "/comment/recipe/replies/{parentId}": {
      "get": {
        "tags": [
          "Comments"
        ],
        "summary": "Obtener respuestas de un comentario",
        "parameters": [
          {
            "name": "parentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de respuestas obtenida"
          }
        }
      }
    },
    "/comment/recipe/{commentId}": {
      "put": {
        "tags": [
          "Comments"
        ],
        "summary": "Actualizar contenido de un comentario",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "commentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comentario actualizado"
          }
        }
      },
      "delete": {
        "tags": [
          "Comments"
        ],
        "summary": "Eliminar un comentario",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "commentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Comentario eliminado"
          }
        }
      }
    }
  }
}